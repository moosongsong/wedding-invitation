# 이 파일을 복사해 .env 로 만들고 값을 채우세요. (cp .env.example .env)
# .env 는 git 에 커밋되지 않습니다. 실제 값은 GitHub Secret 으로만 관리하세요.

# 네이버 지도 키 (Naver Cloud Platform > Maps 의 ncpKeyId)
VITE_NAVER_MAP_KEY=your-naver-map-key

# 예식 일시 (ISO) · 장소
VITE_WEDDING_DATE=2030-12-25T11:00:00   # 이 값 하나로 달력/카운트다운/문구 자동 생성
VITE_VENUE_NAME=              # 예식장 이름 (헤더)
VITE_VENUE_HALL=              # 홀/장소명
VITE_VENUE_ADDRESS=           # 주소
VITE_CEREMONY_NAME=           # 지도 마커: 예식장
VITE_CEREMONY_LAT=            # 예식장 위도
VITE_CEREMONY_LNG=            # 예식장 경도
VITE_RECEPTION_NAME=          # 지도 마커: 피로연장
VITE_RECEPTION_LAT=           # 피로연장 위도
VITE_RECEPTION_LNG=           # 피로연장 경도
VITE_OG_DESC=                 # 공유 미리보기 설명 (예: 2027년 ... · 장소)

# 이름 (미설정 시 코드의 일반 명칭 fallback 표시)
VITE_GROOM_NAME=          # 신랑 이름 (예: 홍길동)
VITE_GROOM_NAME_EN=       # 신랑 영문 (예: GILDONG)
VITE_GROOM_FIRST=         # 신랑 이름(성 제외, 캐주얼 문구용)
VITE_BRIDE_NAME=          # 신부 이름
VITE_BRIDE_NAME_EN=       # 신부 영문
VITE_BRIDE_FIRST=         # 신부 이름(성 제외)
VITE_GROOM_FATHER=        # 신랑 아버지
VITE_GROOM_MOTHER=        # 신랑 어머니
VITE_BRIDE_FATHER=        # 신부 아버지
VITE_BRIDE_MOTHER=        # 신부 어머니

# 계좌번호 (미설정 시 코드의 예시값 표시)
VITE_ACCOUNT_GROOM=          # 신랑
VITE_ACCOUNT_GROOM_FATHER=   # 신랑 아버지
VITE_ACCOUNT_GROOM_MOTHER=   # 신랑 어머니
VITE_ACCOUNT_BRIDE=          # 신부
VITE_ACCOUNT_BRIDE_FATHER=   # 신부 아버지
VITE_ACCOUNT_BRIDE_MOTHER=   # 신부 어머니

# 전화번호 (미설정 시 코드의 예시값 표시)
VITE_PHONE_GROOM=            # 신랑
VITE_PHONE_GROOM_FATHER=     # 신랑 아버지
VITE_PHONE_GROOM_MOTHER=     # 신랑 어머니
VITE_PHONE_BRIDE=            # 신부
VITE_PHONE_BRIDE_FATHER=     # 신부 아버지
VITE_PHONE_BRIDE_MOTHER=     # 신부 어머니
